<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/snap_bg"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/developerToolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/snap_surface"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:navigationIconTint="@color/snap_text"
        app:title="개발자 소개"
        app:titleTextColor="@color/snap_text" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:background="@drawable/bg_badge_primary"
            android:gravity="center"
            android:text="SM"
            android:textColor="@color/white"
            android:textSize="32sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:gravity="center"
            android:text="SnapMind Team B"
            android:textColor="@color/snap_text"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:text="앱 셸, 이미지 수집 UI, 외부 API 연동, 검색/태그/상세 화면 UI를 담당합니다."
            android:textColor="@color/snap_text_secondary"
            android:textSize="15sp" />
    </LinearLayout>
</LinearLayout>
