<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/snap_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="API 및 처리 상태"
            android:textColor="@color/snap_text"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/apiHealthText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Vision, Gemini, YouTube API는 키가 없으면 자동으로 SKIPPED 처리됩니다."
            android:textColor="@color/snap_text_secondary"
            android:textSize="14sp" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/visionSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:checked="true"
            android:text="Vision 시각 태깅"
            android:textColor="@color/snap_text"
            app:useMaterialThemeColors="true" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/geminiSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:checked="true"
            android:text="Gemini 메모 추천"
            android:textColor="@color/snap_text"
            app:useMaterialThemeColors="true" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/youtubeSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:checked="true"
            android:text="YouTube 딥링크"
            android:textColor="@color/snap_text"
            app:useMaterialThemeColors="true" />

        <TextView
            android:id="@+id/storageText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:background="@drawable/bg_badge_soft"
            android:padding="14dp"
            android:textColor="@color/snap_text"
            android:textSize="14sp" />
    </LinearLayout>
</ScrollView>
