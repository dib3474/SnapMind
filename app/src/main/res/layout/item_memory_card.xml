<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="5dp"
    app:cardBackgroundColor="@color/snap_surface"
    app:cardCornerRadius="8dp"
    app:cardElevation="1dp"
    app:strokeColor="@color/snap_outline"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <FrameLayout
            android:id="@+id/thumbFrame"
            android:layout_width="match_parent"
            android:layout_height="136dp"
            android:background="@drawable/bg_thumbnail_code">

            <ImageView
                android:id="@+id/thumbImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="저장 이미지 미리보기"
                android:scaleType="centerCrop"
                tools:src="@drawable/bg_thumbnail_code" />

            <TextView
                android:id="@+id/thumbGlyph"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:textColor="@color/white"
                android:textSize="34sp"
                android:textStyle="bold"
                tools:text="CODE" />

            <TextView
                android:id="@+id/categoryBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="start|top"
                android:layout_margin="8dp"
                android:background="@drawable/bg_badge_soft"
                android:maxLines="1"
                android:textColor="@color/snap_primary"
                android:textSize="11sp"
                android:textStyle="bold"
                tools:text="Code" />

            <TextView
                android:id="@+id/statusBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end|top"
                android:layout_margin="8dp"
                android:background="@drawable/bg_badge_primary"
                android:maxLines="1"
                android:textColor="@color/white"
                android:textSize="11sp"
                android:textStyle="bold"
                tools:text="완료" />

            <ImageButton
                android:id="@+id/favoriteButton"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="end|bottom"
                android:layout_margin="8dp"
                android:background="@drawable/bg_badge_soft"
                android:contentDescription="즐겨찾기 토글"
                android:padding="9dp"
                android:src="@drawable/ic_heart" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp">

            <TextView
                android:id="@+id/memoText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:lineSpacingExtra="1dp"
                android:maxLines="2"
                android:minHeight="38dp"
                android:textColor="@color/snap_text"
                android:textSize="13sp"
                tools:text="React hydration error - fix before morning meeting" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/timeText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/snap_text_secondary"
                    android:textSize="11sp"
                    tools:text="2시간 전" />

                <TextView
                    android:id="@+id/tagText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxWidth="92dp"
                    android:maxLines="1"
                    android:textColor="@color/snap_primary"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    tools:text="#React_Error" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
