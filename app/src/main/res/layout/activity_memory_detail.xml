<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/snap_bg"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/detailToolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/snap_surface"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:navigationIconTint="@color/snap_text"
        app:title="상세"
        app:titleTextColor="@color/snap_text" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="20dp">

            <FrameLayout
                android:id="@+id/detailPreviewFrame"
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:background="@drawable/bg_thumbnail_code">

                <ImageView
                    android:id="@+id/detailImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="이미지 원본"
                    android:scaleType="centerCrop" />

                <TextView
                    android:id="@+id/detailGlyph"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:textColor="@color/white"
                    android:textSize="42sp"
                    android:textStyle="bold" />
            </FrameLayout>

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/detailChipGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="16dp"
                android:paddingTop="14dp"
                android:paddingEnd="16dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="12dp"
                android:hint="저장 이유 메모">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/memoEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="top"
                    android:inputType="textMultiLine|textCapSentences"
                    android:minLines="4"
                    android:textColor="@color/snap_text" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.chip.Chip
                android:id="@+id/geminiSuggestionChip"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="10dp"
                android:checkable="false"
                android:textColor="@color/snap_primary"
                app:chipBackgroundColor="@color/snap_surface_soft"
                app:closeIconVisible="true"
                app:chipIcon="@drawable/ic_spark"
                app:chipIconTint="@color/snap_primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/youtubeButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="12dp"
                android:text="영상 바로 이동"
                app:icon="@drawable/ic_spark" />

            <TextView
                android:id="@+id/ocrHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_badge_soft"
                android:padding="14dp"
                android:text="OCR 텍스트 보기"
                android:textColor="@color/snap_text"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/ocrText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="8dp"
                android:background="@color/snap_surface"
                android:padding="14dp"
                android:textColor="@color/snap_text_secondary"
                android:textSize="13sp"
                android:visibility="gone" />
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/snap_surface"
        android:orientation="horizontal"
        android:padding="12dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/favoriteDetailButton"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="54dp"
            android:layout_height="52dp"
            android:contentDescription="즐겨찾기"
            app:icon="@drawable/ic_heart"
            app:iconGravity="textStart"
            app:iconPadding="0dp" />

        <Space
            android:layout_width="8dp"
            android:layout_height="1dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/deleteButton"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="54dp"
            android:layout_height="52dp"
            android:contentDescription="휴지통으로 이동"
            app:icon="@drawable/ic_trash"
            app:iconGravity="textStart"
            app:iconPadding="0dp" />

        <Space
            android:layout_width="8dp"
            android:layout_height="1dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/saveMemoButton"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="메모 저장"
            app:icon="@drawable/ic_check" />
    </LinearLayout>
</LinearLayout>
